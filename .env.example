# ── LLM — DeepSeek (generation) ────────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── LLM — Groq (routing / fast inference) ─────────────────────────────────────
GROQ_API_KEY=
ROUTER_MODEL=llama-3.1-8b-instant

# ── Embeddings (OpenAI-compatible — swap EMBED_BASE_URL for any provider) ─────
EMBED_API_KEY=
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_MODEL=text-embedding-3-small

# ── Vector store (Qdrant — local Docker service) ───────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=northwind

# ── Web search ─────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_secret
POSTGRES_DB=northwind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://agent:agent_secret@postgres:5432/northwind

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Arize Phoenix (observability) ──────────────────────────────────────────────
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:4317
PHOENIX_PROJECT_NAME=bi-agent

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173"]
