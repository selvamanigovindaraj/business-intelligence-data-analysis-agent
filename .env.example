# ── LLM ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Vector store (Pinecone — cloud hosted) ─────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=ai-agent-index
PINECONE_ENVIRONMENT=us-east-1-aws

# ── Web search ─────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Postgres ───────────────────────────────────────────────────────────────────
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_secret
POSTGRES_DB=agent_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://agent:agent_secret@postgres:5432/agent_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Arize Phoenix (observability) ──────────────────────────────────────────────
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:4317
PHOENIX_PROJECT_NAME=bi-agent

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
